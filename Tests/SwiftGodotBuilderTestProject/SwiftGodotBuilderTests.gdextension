[configuration]
entry_symbol = "swift_entry_point"
compatibility_minimum = 4.2

[libraries]
macos.debug = "res://bin/libSwiftGodotBuilderTestExtension.dylib"
macos.release = "res://bin/libSwiftGodotBuilderTestExtension.dylib"
linux.debug = "res://bin/libSwiftGodotBuilderTestExtension.so"
linux.release = "res://bin/libSwiftGodotBuilderTestExtension.so"

[dependencies]
macos.debug = {"res://bin/libSwiftGodotBuilder.dylib": "", "res://bin/libSwiftGodot.dylib": ""}
macos.release = {"res://bin/libSwiftGodotBuilder.dylib": "", "res://bin/libSwiftGodot.dylib": ""}
linux.debug = {"res://bin/libSwiftGodotBuilder.so": "", "res://bin/libSwiftGodot.so": ""}
linux.release = {"res://bin/libSwiftGodotBuilder.so": "", "res://bin/libSwiftGodot.so": ""}
